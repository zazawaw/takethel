local function mkCorner(p, r)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, r or 8)
    c.Parent = p
end

local function mkStroke(p, col, thick)
    local s = Instance.new("UIStroke")
    s.Color = col or ACCENT
    s.Thickness = thick or 1
    s.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    s.Parent = s
    s.Parent = p
end

local function mkPad(p, l,r,t,b)
    local pad = Instance.new("UIPadding")
    pad.PaddingLeft   = UDim.new(0, l or 0)
    pad.PaddingRight  = UDim.new(0, r or 0)
    pad.PaddingTop    = UDim.new(0, t or 0)
    pad.PaddingBottom = UDim.new(0, b or 0)
    pad.Parent = p
end

-- Touch/mouse drag
local function mkDrag(frame, handle)
    local drag, dstart, fstart = false, nil, nil
    local h = handle or frame
    h.InputBegan:Connect(function(inp)
        if inp.UserInputType==Enum.UserInputType.Touch or inp.UserInputType==Enum.UserInputType.MouseButton1 then
            drag=true; dstart=inp.Position; fstart=frame.Position
            inp.Changed:Connect(function()
                if inp.UserInputState==Enum.UserInputState.End then drag=false end
            end)
        end
    end)
    UserInputService.InputChanged:Connect(function(inp)
        if drag and (inp.UserInputType==Enum.UserInputType.Touch or inp.UserInputType==Enum.UserInputType.MouseMovement) then
            local d = inp.Position - dstart
            frame.Position = UDim2.new(fstart.X.Scale, fstart.X.Offset+d.X, fstart.Y.Scale, fstart.Y.Offset+d.Y)
        end
    end)
end


    end
    notify("Anim React", v and "ON" or "OFF", v)
end)

-- ── Tackle React ───────────────────────────────────────────
mkSection(tReacts, "Tackle React")

local tackleReactOn   = false
local tackleReactConn = nil
local TACKLE_NAMES = {
    "Tackle","TackleL","TackleR","SlideTackle","SlideTackleL",
    "OldTackle","OldTackleL","OldTackleR","StandingTackle",
}
local TACKLE_DIST = 7
local function hookTackleReact()
    if tackleReactConn then tackleReactConn:Disconnect(); tackleReactConn=nil end
    if not tackleReactOn then return end
    local char = lplr.Character; if not char then return end
    local hum  = char:FindFirstChildOfClass("Humanoid"); if not hum then return end
    tackleReactConn = hum.AnimationPlayed:Connect(function(track)
        if not table.find(TACKLE_NAMES, track.Name) then return end
        local TPS  = GetTPS(); if not TPS then return end
        local root = char:FindFirstChild("HumanoidRootPart"); if not root then return end
        if (root.Position - TPS.Position).Magnitude > TACKLE_DIST then return end
        local limb = GetLimb(char, hum); if not limb then return end
        -- pause reach and block all other reacts during tackle
        local wasReachOn = reachOn
        if wasReachOn then reachOn=false; rebuildReach() end
        tackling = true
        -- wait 2 frames so reach loop fully stops before firing
        task.delay(0.18 + math.random(0,5)*0.01, function()
            if not (limb.Parent and TPS.Parent) then
                if wasReachOn then reachOn=true; rebuildReach() end
                tackling = false; return
            end
            local t2 = GetTPS(); if not t2 then
                if wasReachOn then reachOn=true; rebuildReach() end
                tackling = false; return
            end
            if (root.Position - t2.Position).Magnitude > TACKLE_DIST then
                if wasReachOn then reachOn=true; rebuildReach() end
                tackling = false; return
            end
            firetouchinterest(limb, t2, 0); firetouchinterest(limb, t2, 1)
            -- also fire from head during tackle for extra coverage
            local head = char:FindFirstChild("Head")
            if head then
                firetouchinterest(head, t2, 0); firetouchinterest(head, t2, 1)
            end
        end)
        task.delay(0.65, function()
            if wasReachOn then reachOn=true; rebuildReach() end
            tackling = false
        end)
        track.Stopped:Connect(function()
            if wasReachOn and not reachOn then reachOn=true; rebuildReach() end
            tackling = false
        end)
    end)
end

mkToggle(tReacts, "Tackle React", "Fires react on tackle anim, reach auto-pauses", false, function(v)
    tackleReactOn = v
    if v then hookTackleReact() else
        if tackleReactConn then tackleReactConn:Disconnect(); tackleReactConn=nil end
    end
    notify("Tackle React", v and "ON" or "OFF", v)
end)


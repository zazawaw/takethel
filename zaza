local function mkSlider(tab, title, mn, mx, def, step, cb)
    local val = def or mn
    step = step or 1

    local f = Instance.new("Frame")
    f.Size=UDim2.new(1,0,0,58)
    f.BackgroundColor3=ELEM; f.BorderSizePixel=0
    f.LayoutOrder=tab.order; tab.order+=1; f.Parent=tab.page
    mkCorner(f,7)

    local row = Instance.new("Frame")
    row.Size=UDim2.new(1,-16,0,20); row.Position=UDim2.new(0,8,0,7)
    row.BackgroundTransparency=1; row.Parent=f

    local tl=Instance.new("TextLabel"); tl.Size=UDim2.new(0.7,0,1,0)
    tl.BackgroundTransparency=1; tl.Text=title; tl.TextSize=12
    tl.Font=Enum.Font.GothamSemibold; tl.TextColor3=TXT
    tl.TextXAlignment=Enum.TextXAlignment.Left; tl.Parent=row

    local vl=Instance.new("TextLabel"); vl.Size=UDim2.new(0.3,0,1,0)
    vl.Position=UDim2.new(0.7,0,0,0); vl.BackgroundTransparency=1
    vl.Text=tostring(val); vl.TextSize=12; vl.Font=Enum.Font.GothamBold
    vl.TextColor3=ACCENT; vl.TextXAlignment=Enum.TextXAlignment.Right; vl.Parent=row

    local track=Instance.new("Frame")
    track.Size=UDim2.new(1,-16,0,6); track.Position=UDim2.new(0,8,0,36)
    track.BackgroundColor3=SECT; track.BorderSizePixel=0; track.Parent=f
    mkCorner(track,3)

    local fill=Instance.new("Frame")
    fill.Size=UDim2.new((val-mn)/(mx-mn),0,1,0)
    fill.BackgroundColor3=ACCENT; fill.BorderSizePixel=0; fill.Parent=track
    mkCorner(fill,3)

    local knob=Instance.new("Frame")
    knob.Size=UDim2.new(0,16,0,16); knob.AnchorPoint=Vector2.new(0.5,0.5)
    knob.Position=UDim2.new((val-mn)/(mx-mn),0,0.5,0)
    knob.BackgroundColor3=WHITE; knob.BorderSizePixel=0; knob.ZIndex=3; knob.Parent=track
    mkCorner(knob,8)

    local dragging=false
    local function upd(ax)
        local rel=math.clamp((ax-track.AbsolutePosition.X)/track.AbsoluteSize.X,0,1)
        val=math.floor(((mn+rel*(mx-mn))/step)+0.5)*step
        val=math.clamp(val,mn,mx)
        local pct=(val-mn)/(mx-mn)
        fill.Size=UDim2.new(pct,0,1,0)
        knob.Position=UDim2.new(pct,0,0.5,0)
        vl.Text=tostring(val)
        cb(val)
    end

    local hit=Instance.new("TextButton")
    hit.Size=UDim2.new(1,0,1,0); hit.BackgroundTransparency=1; hit.Text=""; hit.Parent=f
    hit.InputBegan:Connect(function(inp)
        if inp.UserInputType==Enum.UserInputType.Touch or inp.UserInputType==Enum.UserInputType.MouseButton1 then
            dragging=true; upd(inp.Position.X)
        end
    end)
    UserInputService.InputChanged:Connect(function(inp)
        if dragging and (inp.UserInputType==Enum.UserInputType.Touch or inp.UserInputType==Enum.UserInputType.MouseMovement) then
            upd(inp.Position.X)
        end
    end)
    UserInputService.InputEnded:Connect(function(inp)
        if inp.UserInputType==Enum.UserInputType.Touch or inp.UserInputType==Enum.UserInputType.MouseButton1 then
            dragging=false
        end
    end)
end


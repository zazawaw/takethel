-- Detects nearest opponent with the ball and fires tackle remote.
mkSection(tAuto, "Auto Tackle")
mkParagraph(tAuto, "How it works",
    "Automatically fires tackle when an opponent is close to you and has the ball. Enable it and just run at people.")

local autoTackleOn   = false
local autoTackleConn = nil
local autoTackleDist = 5
local autoTackleLast = 0
local autoTackleCooldown = 1.2  -- tackle has a real cooldown in-game

mkToggle(tAuto, "Auto Tackle", "Auto tackles opponents near the ball", false, function(state)
    autoTackleOn = state
    if autoTackleConn then autoTackleConn:Disconnect(); autoTackleConn=nil end
    if not state then notify("Auto Tackle","OFF",false) return end
    autoTackleConn = RunService.Heartbeat:Connect(function()
        local now = tick()
        if (now - autoTackleLast) < autoTackleCooldown then return end
        local c    = lplr.Character
        local root = c and c:FindFirstChild("HumanoidRootPart")
        if not (c and root) then return end
        local TPS = GetTPS(); if not TPS then return end
        -- find closest opponent near the ball
        local closest, closestDist = nil, autoTackleDist
        for _, p in ipairs(Players:GetPlayers()) do
            if p == lplr then continue end
            local pc = p.Character
            local pr = pc and pc:FindFirstChild("HumanoidRootPart")
            if not pr then continue end
            -- check opponent is close to ball AND close to us
            local oppToBall = (pr.Position - TPS.Position).Magnitude
            local oppToMe   = (root.Position - pr.Position).Magnitude
            if oppToBall < 4 and oppToMe < closestDist then
                closestDist = oppToMe
                closest = pc
            end
        end
        if not closest then return end
        autoTackleLast = now
        local actions = workspace:FindFirstChild("FE") and workspace.FE:FindFirstChild("Actions")
        if not actions then return end
        local ev = actions:FindFirstChild("Tackle")
        if ev then pcall(function() ev:FireServer(TPS, root) end) end
    end)
    notify("Auto Tackle","ON",true)
end)

    magnetOn = state
    if magnetConn then magnetConn:Disconnect(); magnetConn=nil end
    if not state then notify("Magnet","OFF",false) return end
    magnetConn = RunService.Heartbeat:Connect(function()
        local c    = lplr.Character
        local root = c and c:FindFirstChild("HumanoidRootPart")
        if not (c and root) then return end
        local TPS = GetTPS(); if not TPS then return end
        local dist = (root.Position - TPS.Position).Magnitude
        if dist > 18 or dist < 1.5 then return end  -- don't pull from too far or if already at feet
        -- lerp ball position gently toward player feet
        local targetPos = root.Position + Vector3.new(0,-2.5,0) + (root.CFrame.LookVector * 1.5)
        TPS.CFrame = TPS.CFrame:Lerp(CFrame.new(targetPos), magnetStr)
    end)
    notify("Magnet","ON",true)
end)

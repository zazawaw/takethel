local function GetLimb(char, hum)
    local pf = Lighting:FindFirstChild(lplr.Name)
    local pfoot = pf and pf:FindFirstChild("PreferredFoot")
    if not pfoot then return nil end
    if hum.RigType == Enum.HumanoidRigType.R6 then
        return char:FindFirstChild(pfoot.Value==1 and "Right Leg" or "Left Leg")
    else
        return char:FindFirstChild(pfoot.Value==1 and "RightLowerLeg" or "LeftLowerLeg")
    end
end


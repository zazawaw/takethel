local function openTab(tabData)
    if ActiveTab then
        ActiveTab.page.Visible = false
        ActiveTab.btn.BackgroundColor3 = ELEM
        ActiveTab.btn.TextColor3 = SUB
    end
    tabData.page.Visible = true
    tabData.btn.BackgroundColor3 = ACCENT2
    tabData.btn.TextColor3 = WHITE
    ActiveTab = tabData
end

local function mkTab(name, icon)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0,0,0,26)
    btn.AutomaticSize = Enum.AutomaticSize.X
    btn.BackgroundColor3 = ELEM
    btn.Text = (icon and icon.."  " or "")..name
    btn.TextSize = 11
    btn.Font = Enum.Font.GothamSemibold
    btn.TextColor3 = SUB
    btn.BorderSizePixel = 0
    btn.LayoutOrder = #Tabs+1
    btn.ZIndex = 5
    btn.Parent = TabStrip
    mkCorner(btn, 5)
    mkPad(btn, 8,8,0,0)

    local page = Instance.new("ScrollingFrame")
    page.Size = UDim2.new(1,0,1,0)
    page.BackgroundTransparency = 1
    page.BorderSizePixel = 0
    page.ScrollBarThickness = 3
    page.ScrollBarImageColor3 = ACCENT
    page.CanvasSize = UDim2.new(0,0,0,0)
    page.AutomaticCanvasSize = Enum.AutomaticSize.Y
    page.Visible = false
    page.ZIndex = 2
    page.Parent = ContentArea

    local lay = Instance.new("UIListLayout")
    lay.Padding = UDim.new(0,6)
    lay.SortOrder = Enum.SortOrder.LayoutOrder
    lay.Parent = page
    mkPad(page, 8,8,8,8)

    local td = {btn=btn, page=page, name=name, order=0}
    btn.MouseButton1Click:Connect(function() openTab(td) end)
    table.insert(Tabs, td)
    return td
end


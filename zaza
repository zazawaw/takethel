local rcColConn; local rcFollower
local rcAutoConn; local rcAutoOn=false; local rcAutoDist=4
local rcTouchConn

-- Shared cooldown system — one cooldown across ALL react methods
-- so only ONE react fires per cooldown window, looking legit
local RC_COOLDOWN = 0.35   -- seconds between reacts (adjustable)
local rcLastFired  = 0
local rcBusy       = false  -- prevents double-firing within same window
local tackling     = false  -- blocks all other reacts during tackle animation

local function canFireReact()
    local now = tick()
    if rcBusy then return false end
    if tackling then return false end  -- block all reacts during tackle
    if (now - rcLastFired) < RC_COOLDOWN then return false end
    return true
end

local function doReact(c, hum, TPS)
    if not canFireReact() then return end
    local limb = GetLimb(c, hum)
    if not limb then return end
    rcBusy = true
    rcLastFired = tick()
    firetouchinterest(limb, TPS, 0)
    firetouchinterest(limb, TPS, 1)
    -- small random jitter so it never fires at exactly the same interval
    task.delay(RC_COOLDOWN + math.random(0,8)*0.01, function()
        rcBusy = false
    end)
end


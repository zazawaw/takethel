mkSection(tReacts, "Animation React")

local animReactOn   = false
local animReactConn = nil
local ANIM_NAMES = {
    "OldMKickL","OldMKick","OldLKickL","OldLKick",
    "MKickL","MKick","LKickL","LKick",
    "OldDribbleL","OldDribble","DribbleL","Dribble",
    "Header","Volley","VolleyL",
}
local ANIM_DIST = 4

local function hookAnimReact()
    if animReactConn then animReactConn:Disconnect(); animReactConn=nil end
    if not animReactOn then return end
    local char = lplr.Character; if not char then return end
    local hum  = char:FindFirstChildOfClass("Humanoid"); if not hum then return end
    animReactConn = hum.AnimationPlayed:Connect(function(track)
        if not table.find(ANIM_NAMES, track.Name) then return end
        if not canFireReact() then return end  -- respect shared cooldown
        local TPS  = GetTPS(); if not TPS then return end
        local root = char:FindFirstChild("HumanoidRootPart"); if not root then return end
        -- hard distance check — must be physically close
        if (root.Position - TPS.Position).Magnitude > ANIM_DIST then return end
        local limb = GetLimb(char, hum); if not limb then return end
        task.delay(0.06 + math.random(0,4)*0.01, function()
            if tackling then return end  -- cancelled if tackle started
            if not (limb.Parent and TPS.Parent) then return end
            local t2 = GetTPS(); if not t2 then return end
            -- re-check after delay
            if (root.Position - t2.Position).Magnitude > ANIM_DIST then return end
            firetouchinterest(limb, t2, 0)
            firetouchinterest(limb, t2, 1)
        end)
    end)
end

mkToggle(tReacts, "Animation React", "Fires react when kick/dribble anim plays near ball", false, function(v)
    animReactOn = v
    if v then hookAnimReact() else

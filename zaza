-- ── 2. Smart React ──────────────────────────────────────────
-- Only fires when the ball is actually moving TOWARDS you,
-- not when it's rolling away. Prevents false reacts.
mkSection(tAuto, "Smart React")
mkParagraph(tAuto, "How it works",
    "Checks ball velocity direction. Only fires if the ball is coming toward you. Prevents wasted reacts on balls moving away.")

local smartOn   = false
local smartConn = nil
local smartDist = 7
local smartLastPos = nil

mkToggle(tAuto, "Smart React", "Only reacts when ball is heading toward you", false, function(state)
    smartOn = state
    if smartConn then smartConn:Disconnect(); smartConn=nil end
    if not state then notify("Smart React","OFF",false) return end
    smartConn = RunService.Heartbeat:Connect(function()
        if not canFireReact() then return end
        local c    = lplr.Character
        local root = c and c:FindFirstChild("HumanoidRootPart")
        local hum  = c and c:FindFirstChildOfClass("Humanoid")
        if not (c and root and hum) then return end
        local TPS = GetTPS(); if not TPS then return end
        local dist = (root.Position - TPS.Position).Magnitude
        if dist > smartDist then smartLastPos=nil; return end
        -- check if ball is moving toward player using dot product
        local toPlayer = (root.Position - TPS.Position).Unit
        local ballVel  = TPS.AssemblyLinearVelocity
        if ballVel.Magnitude < 0.5 then return end  -- ball barely moving, skip
        local dot = toPlayer:Dot(ballVel.Unit)
        if dot > 0.3 then  -- ball is heading toward player (positive dot = same direction)
            doReact(c, hum, TPS)
        end
    end)
    notify("Smart React","ON",true)
end)
mkSlider(tAuto, "Smart React Distance", 3, 15, 7, 1, function(v) smartDist=v end)

